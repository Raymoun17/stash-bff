DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stash
JWT_SECRET=replace-with-a-long-random-secret
PORT=3000
REFRESH_COOKIE_PATH=/auth
REFRESH_COOKIE_SECURE=false

# Product scraping: local uses the in-process Playwright fallback; remote uses
# the private FastAPI/Camoufox worker.
SCRAPER_MODE=local
SCRAPER_WORKER_URL=http://localhost:8000
SCRAPER_SERVICE_TOKEN=dev-secret-change-me
INTEGRATION_TIMEOUT_MS=20000
INTEGRATION_MAX_CONCURRENCY=2
INTEGRATION_MAX_HTML_BYTES=10000000

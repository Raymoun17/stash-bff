# Standalone BFF configuration. Assumes PostgreSQL and the scraper worker run
# locally. Docker Compose overrides their hostnames through stash-infra/.env.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://admin:admin@localhost:5432/stash

JWT_SECRET=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_COOKIE_NAME=stash_refresh
# Use /api/auth when this BFF is served through the Next.js /api proxy.
REFRESH_COOKIE_PATH=/auth
REFRESH_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3001

SCRAPER_WORKER_URL=http://localhost:8000
SCRAPER_SERVICE_TOKEN=replace-with-the-same-token-as-the-scraper-worker
INTEGRATION_TIMEOUT_MS=20000
INTEGRATION_MAX_HTML_BYTES=10000000

# Optional AI extraction. Leave blank to disable Gemini extraction.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
AI_EXTRACTION_PROMPT_PATH=prompts/product-extraction.md

# Used by `npm run dev:price-refresher` / `npm run start:price-refresher`.
PRICE_REFRESH_INTERVAL_MS=86400000
PRICE_REFRESH_BATCH_SIZE=100
PRICE_REFRESH_CONCURRENCY=2

# Optional URL used only by the Zara smoke-test script.
ZARA_SMOKE_URL=
